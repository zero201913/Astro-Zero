﻿﻿---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import MobileDrawer from "../components/MobileDrawer.astro";
import PostCard from "../components/PostCard.astro";
import TerminalQuote from "../components/TerminalQuote.astro";
import {
	BILIBILI_URL,
	CREATINF_URL,
	GITHUB_URL,
	SITE_DESCRIPTION,
	SITE_TITLE,
} from "../consts";

const BASE = import.meta.env.BASE_URL;
// Keep home preview aligned with list pagination size for consistent editorial cadence.
const posts = (await getCollection("blog"))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);

const HOME_WALLPAPER = `${BASE}image/home/sakura.webm`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<MobileDrawer />
		<main
			class="page-shell page-fade-in py-10 md:py-14"
			transition:name="page-main"
			transition:animate="fade"
		>
			<div class="space-y-6">
				<section
					class="hero-enter overflow-hidden rounded-2xl border border-zinc-200 bg-white dark:border-zinc-700 dark:bg-zinc-900"
				>
					<div
						class="relative h-[44vh] min-h-[300px] w-full"
						id="hero-video-container"
					>
						<!-- Loading overlay with centered animation -->
						<div
							id="video-loading-overlay"
							class="absolute inset-0 z-20 flex items-center justify-center bg-gradient-to-br from-zinc-100 to-zinc-200 dark:from-zinc-800 dark:to-zinc-900 transition-opacity duration-700"
						>
							<div class="flex flex-col items-center gap-4">
								<!-- Spinner animation -->
								<div class="relative">
									<div
										class="h-12 w-12 rounded-full border-4 border-zinc-300 dark:border-zinc-600"
									>
									</div>
									<div
										class="absolute inset-0 h-12 w-12 rounded-full border-4 border-transparent border-t-blue-500 animate-spin"
									>
									</div>
								</div>
								<!-- Loading text -->
								<p
									class="text-sm font-medium text-zinc-500 dark:text-zinc-400 animate-pulse"
								>
									加载中...
								</p>
							</div>
						</div>
						<!-- Video element with loading handler -->
						<video
							id="hero-video"
							autoplay
							muted
							loop
							playsinline
							preload="auto"
							class="h-full w-full object-cover opacity-0 transition-opacity duration-1000"
						>
							<source src={HOME_WALLPAPER} type="video/webm" />
							Your browser does not support the video tag.
						</video>
						<div
							class="absolute inset-0 bg-zinc-900/10 dark:bg-zinc-950/25"
						>
						</div>
					</div>
				</section>

				<section
					class="section-enter section-enter-delay-1 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 items-start"
				>
					<div class="hero-enter hero-enter-delay-2">
						<h1
							class="font-sans text-3xl font-semibold leading-tight tracking-tight text-zinc-900 dark:text-zinc-100 md:text-4xl"
							transition:name="page-title"
							transition:animate="fade"
						>
							{SITE_TITLE}
						</h1>
						<p
							class="mt-2 font-sans text-sm text-zinc-500 dark:text-zinc-400"
						>
							Welcome to my blog.
						</p>
						<p
							class="mt-1 font-sans text-sm text-zinc-500 dark:text-zinc-400"
						>
							{SITE_DESCRIPTION}
						</p>
						<div class="mt-3 flex flex-wrap gap-2">
							<span
								class="rounded-lg border border-zinc-200 px-2.5 py-1 text-xs font-medium text-zinc-600 dark:border-zinc-700 dark:text-zinc-300"
							>
								UI: English
							</span>
							<span
								class="rounded-lg border border-zinc-200 px-2.5 py-1 text-xs font-medium text-zinc-600 dark:border-zinc-700 dark:text-zinc-300"
							>
								Content: Chinese (long-form)
							</span>
						</div>
						<div class="mt-4 flex items-center gap-2">
							<a
								href={GITHUB_URL}
								target="_blank"
								rel="noreferrer"
								class="icon-button inline-flex h-10 w-10 items-center justify-center rounded-xl border border-zinc-200 text-zinc-600 transition-colors hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-zinc-100"
								aria-label="GitHub"
							>
								<svg
									viewBox="0 0 24 24"
									class="h-5 w-5 fill-current"
									aria-hidden="true"
								>
									<path
										d="M12 .3A12 12 0 0 0 8.2 23.7c.6.1.8-.2.8-.6v-2.3c-3.3.7-4-1.4-4-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.1.1 1.8 1.1 1.8 1.1 1 .1 1.6.7 2 1.3.9.2 1.8.4 2.7.1.1-.7.4-1.3.7-1.7-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.1-3.2-.1-.3-.5-1.5.1-3.2 0 0 .9-.3 3.2 1.1a10.9 10.9 0 0 1 5.9 0c2.2-1.4 3.2-1.1 3.2-1.1.6 1.7.2 2.9.1 3.2.7.8 1.1 1.9 1.1 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6A12 12 0 0 0 12 .3"
									></path>
								</svg>
								<span class="sr-only">GitHub</span>
							</a>
							<a
								href={BILIBILI_URL}
								target="_blank"
								rel="noreferrer"
								class="icon-button inline-flex h-10 w-10 items-center justify-center rounded-xl border border-zinc-200 text-zinc-600 transition-colors hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-zinc-100"
								aria-label="Bilibili"
							>
								<svg
									viewBox="0 0 24 24"
									class="h-5 w-5 fill-current"
									aria-hidden="true"
								>
									<path
										d="M7.4 2.8a1 1 0 0 1 1.4 0L12 6l3.2-3.2a1 1 0 1 1 1.4 1.4L14.5 6.3h3.8A3.7 3.7 0 0 1 22 10v8.3A3.7 3.7 0 0 1 18.3 22H5.7A3.7 3.7 0 0 1 2 18.3V10a3.7 3.7 0 0 1 3.7-3.7h3.8L7.4 4.2a1 1 0 0 1 0-1.4ZM5.7 8.3A1.7 1.7 0 0 0 4 10v8.3c0 .9.8 1.7 1.7 1.7h12.6c.9 0 1.7-.8 1.7-1.7V10c0-.9-.8-1.7-1.7-1.7H5.7Zm1.8 3a1 1 0 0 1 1 1v3.4a1 1 0 1 1-2 0v-3.4a1 1 0 0 1 1-1Zm9 0a1 1 0 0 1 1 1v3.4a1 1 0 1 1-2 0v-3.4a1 1 0 0 1 1-1Z"
									></path>
								</svg>
								<span class="sr-only">Bilibili</span>
							</a>
							<a
								href={CREATINF_URL}
								target="_blank"
								rel="noreferrer"
								class="icon-button inline-flex h-10 w-10 items-center justify-center rounded-xl border border-zinc-200 text-zinc-600 transition-colors hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-zinc-100"
								aria-label="CreatInf"
							>
								<span class="text-lg font-semibold leading-none"
									>∞</span
								>
								<span class="sr-only">CreatInf</span>
							</a>
						</div>
					</div>

					<div
						class="hero-enter hero-enter-delay-2 w-full max-w-sm justify-self-end"
					>
						<TerminalQuote />
					</div>
				</section>
			</div>

			<section class="section-enter section-enter-delay-2 mt-10">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="text-xl font-semibold tracking-tight">
						Latest Posts
					</h2>
					<a
						href={`${BASE}blog/`}
						class="text-sm font-medium text-blue-600 no-underline hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
						>View all</a
					>
				</div>
				<ul class="grid gap-4 md:grid-cols-2">
					{
						posts.map((post, idx) => (
							<li
								class="card-enter relative"
								style={`animation-delay: ${160 + idx * 45}ms`}
							>
								<PostCard
									post={post}
									base={BASE}
									titleTag="h3"
									titleClass="mt-2 text-lg font-semibold tracking-tight text-zinc-900 dark:text-zinc-100"
									descriptionClass="mt-2 font-serif text-sm leading-7 text-zinc-600 dark:text-zinc-300"
									maxMobile={3}
									maxDesktop={3}
									reloadOnNavigate={true}
								/>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />

		<script is:inline>
			(function () {
				const video = document.getElementById("hero-video");
				const loadingOverlay = document.getElementById(
					"video-loading-overlay",
				);

				if (!video || !loadingOverlay) return;

				// Minimum loading time to prevent flash (in milliseconds)
				const MIN_LOADING_TIME = 800;
				const startTime = Date.now();

				const hideLoading = () => {
					const elapsed = Date.now() - startTime;
					const remaining = Math.max(0, MIN_LOADING_TIME - elapsed);

					setTimeout(() => {
						// Fade out loading overlay
						loadingOverlay.style.opacity = "0";

						// Fade in video
						video.classList.remove("opacity-0");
						video.classList.add("opacity-100");

						// Remove overlay after transition
						setTimeout(() => {
							loadingOverlay.style.display = "none";
						}, 700);
					}, remaining);
				};

				// Check if video is already loaded
				if (video.readyState >= 3) {
					// Video is already loaded
					hideLoading();
				} else {
					// Wait for video to load
					video.addEventListener("canplay", hideLoading, {
						once: true,
					});
					video.addEventListener("loadeddata", hideLoading, {
						once: true,
					});

					// Fallback: hide loading after 5 seconds even if video hasn't loaded
					setTimeout(() => {
						if (loadingOverlay.style.display !== "none") {
							hideLoading();
						}
					}, 5000);
				}

				// Handle video errors
				video.addEventListener(
					"error",
					() => {
						console.warn("Video failed to load");
						hideLoading();
					},
					{ once: true },
				);
			})();
		</script>
	</body>
</html>
